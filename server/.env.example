# Server Environment Variables
# IMPORTANT: If you received this file with real-looking secrets already filled in,
# rotate ALL credentials immediately: OpenRouter key, Firecrawl key,
# Unstructured key, and JWT secret. Do NOT commit real secrets to version control.

# App
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/neuramemory

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key-here

# OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_REFERER=https://github.com/Gautam7352/NeuraMemory-AI
OPENROUTER_TITLE=NeuraMemory-AI

# JWT config
JWT_SECRET=replace-with-a-random-32-plus-char-secret
JWT_EXPIRES_IN=7d

# Firecrawl
FIRECRAWL_API_KEY=your-firecrawl-api-key-here

# Unstructured OCR (async jobs)
UNSTRUCTURED_API_URL=https://platform.unstructuredapp.io/api/v1
UNSTRUCTURED_API_KEY=your-unstructured-api-key-here
UNSTRUCTURED_TIMEOUT_MS=120000

# Local OCR fallback
OCR_ENABLE_LOCAL_FALLBACK=true
OCR_TESSERACT_LANG=eng
OCR_FORCE=false

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://your-vercel-app.vercel.app

# Chat model (OpenRouter model ID)
CHAT_MODEL=google/gemini-2.0-flash-001
